# Copy to .env for local dev. On Netlify: Site settings → Environment variables.
#
# --- PayPal LIVE (production) ---
# In PayPal Developer Dashboard open your REST app under the **Live** tab (not Sandbox).
# Use the Live Client ID + Secret here and set mode to live.
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Same Live Client ID — Vite bakes this into the client bundle at build time.
VITE_PAYPAL_CLIENT_ID=
#
# Create a Live webhook in PayPal pointing to:
#   https://YOUR_SITE/.netlify/functions/paypal-webhook
# Then paste the webhook ID from PayPal here:
PAYPAL_WEBHOOK_ID=
